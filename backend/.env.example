# Application
APP_NAME="Caliphate International Schools Gusau Ltd"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@db.neon.tech/school_portal?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=caliphate-school

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://yourdomain.com"]

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@caliphateschools.edu.ng

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
