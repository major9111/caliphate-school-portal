# Application
APP_NAME="Caliphate International Schools Gusau Ltd"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security — generate a real value with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — SQLite for local dev, Neon PostgreSQL for production
DATABASE_URL=sqlite:///./caliphate_school.db
# DATABASE_URL=postgresql://user:password@db.neon.tech/school_portal?sslmode=require

# CORS — comma-separated list of allowed frontend origins
# Accepts a JSON array or a plain comma-separated list — both work:
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://yourdomain.com"]
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Frontend URL (used in generated links, e.g. password reset emails if added later)
FRONTEND_URL=http://localhost:5173

# AI Receptionist (Groq) — optional, leave blank to use canned fallback responses
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Email (SMTP) — required for password reset, fee reminders, admission emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@caliphateschools.edu.ng
EMAIL_FROM_NAME=Caliphate International Schools

# Cloudinary — for file/image uploads (optional; falls back to local storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# School details (used in generated PDFs and emails)
SCHOOL_NAME=Caliphate International Schools Gusau Ltd
SCHOOL_ADDRESS=Gusau, Zamfara State, Nigeria
SCHOOL_PHONE=+234 803 000 0000
SCHOOL_EMAIL=info@caliphateschools.edu.ng
SCHOOL_WEBSITE=https://caliphateschools.edu.ng
