# Copy this to .env for local overrides, or set it as an environment
# variable in your Vercel project settings for production.
#
# Without this set, the app falls back to http://localhost:8000/api/v1 —
# which only works on your own machine. On a deployed site this causes
# every API call (login, register, etc.) to silently fail with
# "Cannot connect to server", because the visitor's browser has no
# localhost:8000 to talk to.
#
# Point this at your deployed backend (Railway/Render/etc), including the
# /api/v1 suffix:
VITE_API_URL=https://your-backend-domain.example.com/api/v1
